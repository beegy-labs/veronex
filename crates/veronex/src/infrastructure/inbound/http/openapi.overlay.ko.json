{
  "info": {
    "description": "LLM 추론 게이트웨이 API — LLM 라우팅, 작업 추적, API 키 관리, 클러스터 모니터링."
  },
  "tags": [
    { "name": "inference",  "description": "LLM 추론 작업 제출 및 추적" },
    { "name": "openai",     "description": "OpenAI 호환 채팅 완성" },
    { "name": "keys",       "description": "API 키 관리" },
    { "name": "backends",   "description": "LLM 백엔드 등록 및 라우팅" },
    { "name": "servers",    "description": "GPU 서버 등록 및 메트릭" },
    { "name": "usage",      "description": "토큰 및 요청 사용량 분석" },
    { "name": "dashboard",  "description": "클러스터 전체 통계 및 작업 이력" },
    { "name": "gemini",     "description": "Gemini 요청 제한 정책 관리" },
    { "name": "system",     "description": "헬스 체크 및 Prometheus 타겟" }
  ],
  "paths": {
    "/health": {
      "get": { "summary": "생존 프로브" }
    },
    "/readyz": {
      "get": { "summary": "준비 프로브" }
    },
    "/v1/metrics/targets": {
      "get": {
        "summary": "Prometheus HTTP SD 타겟",
        "description": "OTel Collector를 위한 node-exporter 스크랩 타겟을 반환합니다. 인증 불필요."
      }
    },
    "/v1/inference": {
      "post": { "summary": "추론 작업 제출" }
    },
    "/v1/inference/{job_id}/stream": {
      "get": { "summary": "추론 출력 스트림 (SSE)" }
    },
    "/v1/inference/{job_id}/status": {
      "get": { "summary": "작업 상태 조회" }
    },
    "/v1/inference/{job_id}": {
      "delete": { "summary": "추론 작업 취소" }
    },
    "/v1/chat/completions": {
      "post": {
        "summary": "OpenAI 호환 채팅 완성",
        "description": "OpenAI /v1/chat/completions의 드롭인 대체. SSE를 통한 스트리밍 지원."
      }
    },
    "/v1/keys": {
      "post": { "summary": "API 키 생성" },
      "get":  { "summary": "API 키 목록 조회" }
    },
    "/v1/keys/{id}": {
      "delete": { "summary": "API 키 삭제" },
      "patch":  { "summary": "API 키 활성/비활성 전환" }
    },
    "/v1/usage": {
      "get": { "summary": "사용량 집계 분석" }
    },
    "/v1/usage/{key_id}": {
      "get": { "summary": "키별 사용량 분석" }
    },
    "/v1/usage/{key_id}/jobs": {
      "get": { "summary": "API 키별 작업 목록" }
    },
    "/v1/dashboard/stats": {
      "get": { "summary": "클러스터 전체 통계" }
    },
    "/v1/dashboard/jobs": {
      "get": { "summary": "페이지네이션 작업 목록" }
    },
    "/v1/dashboard/jobs/{id}": {
      "get": { "summary": "작업 상세 조회" }
    },
    "/v1/dashboard/performance": {
      "get": { "summary": "성능 메트릭 (지연시간 / 처리량)" }
    },
    "/v1/backends": {
      "post": { "summary": "LLM 백엔드 등록" },
      "get":  { "summary": "LLM 백엔드 목록" }
    },
    "/v1/backends/{id}": {
      "delete": { "summary": "LLM 백엔드 삭제" },
      "patch":  { "summary": "LLM 백엔드 수정" }
    },
    "/v1/backends/{id}/healthcheck": {
      "post": { "summary": "백엔드 헬스 체크 실행" }
    },
    "/v1/backends/{id}/models": {
      "get": { "summary": "백엔드 사용 가능 모델 목록" }
    },
    "/v1/backends/{id}/models/sync": {
      "post": { "summary": "모델 목록 캐시 강제 갱신" }
    },
    "/v1/backends/{id}/key": {
      "get": { "summary": "백엔드 API 키 확인" }
    },
    "/v1/servers": {
      "post": { "summary": "GPU 서버 등록" },
      "get":  { "summary": "GPU 서버 목록" }
    },
    "/v1/servers/{id}": {
      "patch":  { "summary": "GPU 서버 수정" },
      "delete": { "summary": "GPU 서버 삭제" }
    },
    "/v1/servers/{id}/metrics": {
      "get": {
        "summary": "실시간 노드 메트릭",
        "description": "서버의 node-exporter 엔드포인트에서 실시간 메트릭을 가져옵니다."
      }
    },
    "/v1/servers/{id}/metrics/history": {
      "get": { "summary": "ClickHouse 히스토리 메트릭" }
    },
    "/v1/gemini/policies": {
      "get": { "summary": "Gemini 요청 제한 정책 목록" }
    },
    "/v1/gemini/policies/{model_name}": {
      "put": { "summary": "Gemini 요청 제한 정책 Upsert" }
    }
  }
}
