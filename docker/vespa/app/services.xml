<?xml version="1.0" encoding="utf-8" ?>
<!-- Single-node Vespa configuration for local dev / docker-compose.
     Production: replace hosts.xml + increase redundancy + add content nodes. -->
<services version="1.0">
  <container id="default" version="1.0">
    <search />
    <document-api />
  </container>

  <content id="content" version="1.0">
    <redundancy>1</redundancy>
    <documents>
      <document type="mcp_tools" mode="index" />
    </documents>
    <nodes>
      <node hostalias="node1" distribution-key="0" />
    </nodes>
    <tuning>
      <resource-limits>
        <disk>0.9</disk>
      </resource-limits>
    </tuning>
  </content>
</services>
