# Veronex — LLM Inference Gateway
# Copy this file to .env and fill in the required values.
# Required values are marked with "REQUIRED".
#
# Quick start:
#   cp .env.example .env
#   # Edit .env to set JWT_SECRET and any optional values
#   docker compose up -d

# ── Required ─────────────────────────────────────────────────────────────────

# Secret key for signing JWT tokens. Generate with:
#   openssl rand -hex 32
JWT_SECRET=

# ── Ollama (LLM backend) ──────────────────────────────────────────────────────

# URL of your Ollama instance.
# macOS (Docker Desktop):  http://host.docker.internal:11434
# Linux (host network):    http://172.17.0.1:11434  or  http://localhost:11434
# Remote Ollama server:    http://<ip>:11434
OLLAMA_URL=http://host.docker.internal:11434

# ── Gemini (optional) ────────────────────────────────────────────────────────

# Google Gemini API key. Leave empty to disable Gemini backend.
# Get one at: https://aistudio.google.com/apikey
GEMINI_API_KEY=

# ── CORS ─────────────────────────────────────────────────────────────────────

# Allowed origins for CORS. Use "*" for local dev (default).
# Production: set to a comma-separated list, e.g.:
#   CORS_ALLOWED_ORIGINS=https://app.example.com,https://admin.example.com
CORS_ALLOWED_ORIGINS=*

# ── Bootstrap admin (optional) ───────────────────────────────────────────────

# Default admin API key for the first setup.
# Change this before exposing the service publicly.
NEXT_PUBLIC_VERONEX_ADMIN_KEY=veronex-bootstrap-admin-key

# Auto-create a super admin account on first run (CI/automated deploys).
# Leave empty to use the web setup wizard instead.
BOOTSTRAP_SUPER_USER=
BOOTSTRAP_SUPER_PASS=

# ── Service credentials (dev defaults — change in production) ───────────────

# PostgreSQL
POSTGRES_USER=veronex
POSTGRES_PASSWORD=veronex

# ClickHouse
CLICKHOUSE_USER=veronex
CLICKHOUSE_PASSWORD=veronex

# MinIO (S3-compatible object storage)
MINIO_ROOT_USER=veronex
MINIO_ROOT_PASSWORD=veronex123

# ── Internal service secrets (auto-defaults are safe for local dev) ──────────

# Shared secret between veronex and veronex-analytics.
# Change in production if running on a shared network.
ANALYTICS_SECRET=veronex-analytics-internal-secret

# ── veronex-agent (OTel metrics collector) ───────────────────────────────────

# OTel Collector HTTP endpoint to push metrics to (OTLP/HTTP JSON).
OTEL_HTTP_ENDPOINT=http://otel-collector:4318

# Total number of agent replicas (StatefulSet). Used for modulus sharding:
# each pod owns targets where hash(target) % REPLICA_COUNT == ordinal.
# Single-replica or non-StatefulSet deployments default to 1 (owns all targets).
REPLICA_COUNT=1

# ── ClickHouse data retention ─────────────────────────────────────────────────
# Applied on first volume creation only.
# To change on an existing volume: ALTER TABLE otel_logs MODIFY TTL ...

# Inference + audit log retention (days). Default: 90
# CLICKHOUSE_RETENTION_ANALYTICS_DAYS=90

# Metrics, traces, hardware metrics retention (days). Default: 30
# CLICKHOUSE_RETENTION_METRICS_DAYS=30

# Audit events table retention (days). Default: 365
# CLICKHOUSE_RETENTION_AUDIT_DAYS=365
